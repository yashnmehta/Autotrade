<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ATMWatchSettingsDialog</class>
 <widget class="QDialog" name="ATMWatchSettingsDialog">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>520</width><height>520</height></rect>
  </property>
  <property name="windowTitle">
   <string>ATM Watch Settings</string>
  </property>
  <property name="minimumSize">
   <size><width>500</width><height>400</height></size>
  </property>
  <property name="modal">
   <bool>true</bool>
  </property>
  <property name="styleSheet">
   <string notr="true">
QDialog {
  background-color: #ffffff;
  color: #1e293b;
  font-size: 12px;
}
QGroupBox {
  background-color: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 6px;
  margin-top: 14px;
  padding: 12px 10px 10px 10px;
  font-weight: 600;
  color: #1e293b;
}
QGroupBox::title {
  subcontrol-origin: margin;
  subcontrol-position: top left;
  padding: 2px 8px;
  color: #1e40af;
  font-size: 12px;
}
QLabel {
  color: #475569;
  font-size: 11px;
}
QLabel#m_strikeRangeExampleLabel {
  color: #64748b;
  font-size: 9pt;
}
QSpinBox, QDoubleSpinBox {
  background-color: #ffffff;
  color: #1e293b;
  border: 1px solid #e2e8f0;
  border-radius: 4px;
  padding: 4px 6px;
  min-height: 24px;
  font-size: 12px;
}
QSpinBox:focus, QDoubleSpinBox:focus {
  border-color: #3b82f6;
}
QComboBox {
  background-color: #ffffff;
  color: #1e293b;
  border: 1px solid #e2e8f0;
  border-radius: 4px;
  padding: 4px 8px;
  min-height: 24px;
  font-size: 12px;
}
QComboBox:focus { border-color: #3b82f6; }
QComboBox::drop-down { width: 18px; border: none; }
QComboBox QAbstractItemView {
  background-color: #ffffff;
  color: #1e293b;
  selection-background-color: #dbeafe;
  selection-color: #1e40af;
  border: 1px solid #e2e8f0;
}
QCheckBox {
  color: #1e293b;
  font-size: 12px;
  spacing: 6px;
}
QCheckBox::indicator {
  width: 16px;
  height: 16px;
  border: 1px solid #cbd5e1;
  border-radius: 3px;
  background-color: #ffffff;
}
QCheckBox::indicator:checked {
  background-color: #2563eb;
  border-color: #2563eb;
}
QCheckBox::indicator:disabled {
  background-color: #f1f5f9;
  border-color: #e2e8f0;
}
QPushButton {
  background-color: #f8fafc;
  color: #334155;
  border: 1px solid #e2e8f0;
  border-radius: 4px;
  padding: 6px 16px;
  font-size: 12px;
  font-weight: 500;
  min-width: 80px;
  min-height: 28px;
}
QPushButton:hover { background-color: #f1f5f9; border-color: #94a3b8; }
QPushButton:pressed { background-color: #e2e8f0; }
QPushButton#m_okButton {
  background-color: #2563eb;
  color: #ffffff;
  border-color: #2563eb;
}
QPushButton#m_okButton:hover { background-color: #1d4ed8; }
QPushButton#m_resetButton {
  background-color: #ffffff;
  color: #dc2626;
  border-color: #fca5a5;
}
QPushButton#m_resetButton:hover { background-color: #fef2f2; border-color: #dc2626; }
   </string>
  </property>
  <layout class="QVBoxLayout" name="mainLayout">
   <property name="spacing">
    <number>12</number>
   </property>
   <property name="leftMargin"><number>14</number></property>
   <property name="topMargin"><number>14</number></property>
   <property name="rightMargin"><number>14</number></property>
   <property name="bottomMargin"><number>14</number></property>

   <!-- Strike Selection Group -->
   <item>
    <widget class="QGroupBox" name="m_strikeSelectionGroup">
     <property name="title"><string>Strike Selection</string></property>
     <layout class="QFormLayout" name="strikeFormLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="lblStrikeRange">
        <property name="text"><string>Strike Range:</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QSpinBox" name="m_strikeRangeSpinBox">
        <property name="minimum"><number>0</number></property>
        <property name="maximum"><number>10</number></property>
        <property name="suffix"><string> strikes around ATM</string></property>
        <property name="toolTip"><string>Number of strikes to display on each side of ATM
0 = ATM only (1 strike)
5 = ATM ± 5 (11 strikes total)</string></property>
       </widget>
      </item>
      <item row="1" column="0">
       <spacer name="exampleSpacer">
        <property name="orientation"><enum>Qt::Horizontal</enum></property>
        <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
       </spacer>
      </item>
      <item row="1" column="1">
       <widget class="QLabel" name="m_strikeRangeExampleLabel">
        <property name="text"><string></string></property>
        <property name="wordWrap"><bool>true</bool></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- Update Settings Group -->
   <item>
    <widget class="QGroupBox" name="m_updateSettingsGroup">
     <property name="title"><string>Update Settings</string></property>
     <layout class="QFormLayout" name="updateFormLayout">
      <item row="0" column="0" colspan="2">
       <widget class="QCheckBox" name="m_autoRecalculateCheckbox">
        <property name="text"><string>Auto-calculate on price changes</string></property>
        <property name="toolTip"><string>Enable event-driven ATM calculation</string></property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="lblTimerInterval">
        <property name="text"><string>Timer Interval:</string></property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QSpinBox" name="m_updateIntervalSpinBox">
        <property name="minimum"><number>10</number></property>
        <property name="maximum"><number>300</number></property>
        <property name="suffix"><string> seconds (backup)</string></property>
        <property name="toolTip"><string>Backup timer interval for ATM calculation
Only used if auto-calculate is disabled or events are missed</string></property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QLabel" name="lblThreshold">
        <property name="text"><string>Threshold Multiplier:</string></property>
       </widget>
      </item>
      <item row="2" column="1">
       <widget class="QDoubleSpinBox" name="m_thresholdMultiplierSpinBox">
        <property name="minimum"><double>0.250000000000000</double></property>
        <property name="maximum"><double>1.000000000000000</double></property>
        <property name="singleStep"><double>0.050000000000000</double></property>
        <property name="decimals"><number>2</number></property>
        <property name="toolTip"><string>Price movement threshold for recalculation
0.25 = High sensitivity (quarter strike interval)
0.50 = Default (half strike interval)
1.00 = Conservative (full strike interval)</string></property>
       </widget>
      </item>
      <item row="3" column="0">
       <spacer name="thresholdNoteSpacer">
        <property name="orientation"><enum>Qt::Horizontal</enum></property>
        <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
       </spacer>
      </item>
      <item row="3" column="1">
       <widget class="QLabel" name="lblThresholdNote">
        <property name="text"><string>Recalculates when price moves by multiplier × strike interval</string></property>
        <property name="wordWrap"><bool>true</bool></property>
        <property name="styleSheet"><string>color: #64748b; font-size: 9pt;</string></property>
       </widget>
      </item>
      <item row="4" column="0">
       <widget class="QLabel" name="lblBasePriceSource">
        <property name="text"><string>Base Price Source:</string></property>
       </widget>
      </item>
      <item row="4" column="1">
       <widget class="QComboBox" name="m_basePriceSourceCombo">
        <property name="toolTip"><string>Source for underlying price calculation
Cash: Uses equity/index cash market price
Future: Uses front month futures price</string></property>
        <item><property name="text"><string>Cash (Spot Price)</string></property></item>
        <item><property name="text"><string>Future (Front Month)</string></property></item>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- Greeks Calculation Group -->
   <item>
    <widget class="QGroupBox" name="m_greeksGroup">
     <property name="title"><string>Greeks Calculation</string></property>
     <layout class="QFormLayout" name="greeksFormLayout">
      <item row="0" column="0" colspan="2">
       <widget class="QCheckBox" name="m_enableGreeksCheckbox">
        <property name="text"><string>Enable Greeks calculation</string></property>
        <property name="enabled"><bool>false</bool></property>
        <property name="toolTip"><string>Greeks calculation (IV, Delta, Gamma, etc.) - Coming in Phase 4</string></property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="lblRiskFreeRate">
        <property name="text"><string>Risk-Free Rate:</string></property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QDoubleSpinBox" name="m_riskFreeRateSpinBox">
        <property name="minimum"><double>0.000000000000000</double></property>
        <property name="maximum"><double>10.000000000000000</double></property>
        <property name="singleStep"><double>0.100000000000000</double></property>
        <property name="decimals"><number>2</number></property>
        <property name="suffix"><string> % (RBI Repo Rate)</string></property>
        <property name="enabled"><bool>false</bool></property>
       </widget>
      </item>
      <item row="2" column="0" colspan="2">
       <widget class="QCheckBox" name="m_showGreeksColumnsCheckbox">
        <property name="text"><string>Show Greeks columns (IV, Delta, Gamma, etc.)</string></property>
        <property name="enabled"><bool>false</bool></property>
       </widget>
      </item>
      <item row="3" column="0" colspan="2">
       <widget class="QLabel" name="lblGreeksNote">
        <property name="text"><string>Greeks features will be available in Phase 4</string></property>
        <property name="styleSheet"><string>color: #64748b; font-size: 9pt; font-style: italic;</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- Alerts Group -->
   <item>
    <widget class="QGroupBox" name="m_alertsGroup">
     <property name="title"><string>Alerts</string></property>
     <layout class="QVBoxLayout" name="alertsLayout">
      <item>
       <widget class="QCheckBox" name="m_soundAlertsCheckbox">
        <property name="text"><string>Sound alerts on ATM change</string></property>
        <property name="toolTip"><string>Play sound when ATM strike changes</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="m_visualAlertsCheckbox">
        <property name="text"><string>Visual flash on strike change</string></property>
        <property name="toolTip"><string>Highlight row when ATM strike changes</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="m_systemNotificationsCheckbox">
        <property name="text"><string>System notifications</string></property>
        <property name="toolTip"><string>Show system notifications for ATM changes</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- Bottom Buttons -->
   <item>
    <layout class="QHBoxLayout" name="buttonLayout">
     <item>
      <spacer name="btnSpacer">
       <property name="orientation"><enum>Qt::Horizontal</enum></property>
       <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
      </spacer>
     </item>
     <item>
      <widget class="QPushButton" name="m_resetButton">
       <property name="text"><string>Reset to Defaults</string></property>
      </widget>
     </item>
     <item>
      <spacer name="btnGap">
       <property name="orientation"><enum>Qt::Horizontal</enum></property>
       <property name="sizeType"><enum>QSizePolicy::Fixed</enum></property>
       <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
      </spacer>
     </item>
     <item>
      <widget class="QPushButton" name="m_okButton">
       <property name="text"><string>OK</string></property>
       <property name="default"><bool>true</bool></property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="m_cancelButton">
       <property name="text"><string>Cancel</string></property>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
