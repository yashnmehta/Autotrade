  <property name="styleSheet">
   <string notr="true">
/* ───── Global light-theme stylesheet ───── */
QDialog, QWidget {
    background: #ffffff;
    color: #1e293b;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
}
QSplitter::handle { background: #e2e8f0; width: 2px; }

QTableWidget {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    gridline-color: #f1f5f9;
    color: #1e293b;
    font-size: 12px;
    selection-background-color: #dbeafe;
    selection-color: #1e40af;
    alternate-background-color: #f8fafc;
}
QTableWidget::item { padding: 4px 6px; }
QTableWidget::item:hover { background: #eff6ff; }
QHeaderView::section {
    background: #f8fafc;
    color: #475569;
    padding: 6px 10px;
    border: none;
    border-bottom: 2px solid #e2e8f0;
    font-weight: 700;
    font-size: 10px;
    text-transform: uppercase;
}

QLineEdit {
    background: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    color: #0f172a;
    padding: 6px 10px;
    font-size: 12px;
}
QLineEdit:focus { border-color: #3b82f6; background: #ffffff; }

QLabel { color: #475569; }

QTextEdit {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    color: #334155;
    font-size: 12px;
    padding: 4px;
}

QPushButton {
    background: #f1f5f9;
    color: #334155;
    border: 1px solid #cbd5e1;
    border-radius: 5px;
    padding: 7px 18px;
    font-size: 12px;
    font-weight: 600;
}
QPushButton:hover { background: #e2e8f0; color: #0f172a; border-color: #94a3b8; }
QPushButton:pressed { background: #dbeafe; border-color: #3b82f6; }
QPushButton:disabled { background: #f8fafc; color: #94a3b8; border-color: #e2e8f0; }

QGroupBox {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    margin-top: 14px;
    padding: 12px 10px 10px 10px;
    color: #2563eb;
    font-weight: 700;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px; top: 0;
    padding: 0 6px;
    color: #2563eb;
    background: #f8fafc;
}

QScrollArea { border: none; background: transparent; }
QScrollBar:vertical { background: #f1f5f9; width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: #cbd5e1; border-radius: 4px; min-height: 24px; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }

/* ── Title bar ── */
QWidget#titleBar {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #1e40af, stop:1 #2563eb);
}
QLabel#titleLabel {
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    background: transparent;
}

/* ── List header ── */
QLabel#listHeader {
    color: #1e293b;
    font-size: 13px;
    background: transparent;
}

/* ── Action buttons ── */
QPushButton#createBtn {
    background: #eff6ff;
    color: #1d4ed8;
    border: 1px solid #bfdbfe;
}
QPushButton#createBtn:hover {
    background: #dbeafe;
    color: #1e40af;
    border-color: #93c5fd;
}
QPushButton#deleteBtn {
    background: #fef2f2;
    color: #dc2626;
    border: 1px solid #fecaca;
}
QPushButton#deleteBtn:hover {
    background: #fee2e2;
    color: #b91c1c;
    border-color: #fca5a5;
}

/* ── Detail pane ── */
QLabel#detailTitle {
    color: #1e293b;
    font-size: 14px;
    font-weight: 700;
    background: transparent;
}
QLabel#detailMeta {
    color: #64748b;
    font-size: 11px;
    background: transparent;
}
QLabel#detailSymbols, QLabel#detailIndicators,
QLabel#detailParams, QLabel#detailRisk {
    color: #334155;
    font-size: 11px;
    background: transparent;
}

/* ── Deploy button ── */
QPushButton#deployBtn {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #16a34a, stop:1 #15803d);
    color: white;
    font-weight: 700;
    font-size: 13px;
    border-radius: 6px;
    border: none;
    padding: 8px 24px;
}
QPushButton#deployBtn:hover { background: #22c55e; }
QPushButton#deployBtn:disabled {
    background: #f0fdf4;
    color: #86efac;
    border: 1px solid #bbf7d0;
}

/* ── Bottom bar ── */
QWidget#bottomBar {
    background: #f8fafc;
    border-top: 2px solid #e2e8f0;
}
QLabel#countLabel {
    color: #64748b;
    font-size: 11px;
    background: transparent;
}
